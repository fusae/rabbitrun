<section>
  <h2>项目</h2>
    {% for project in collections.projects %}
      {% if project.data.featured %}
        <div class="item">
          <span class="year">{{ project.data.year }}</span> <b><a href="{{ project | projectUrl }}">{{ project.data.title }}</a></b> —
          <span class="desc">{{ project.templateContent | striptags | trim }}</span>
          <span class="meta">{{ project.data.language }}{% if project.data.stars %} · ⭐ {{ project.data.stars }}{% endif %}</span>
        </div>
      {% endif %}
    {% endfor %}
  <p><a href="/projects/">→ 全部项目</a></p>
</section>

<section>
  <h2>文章</h2>
  <ul class="posts">
    {% for post in collections.posts %}
      {% if loop.index <= 5 %}
      <li>
        <span class="date">{{ post.data.date | htmlDateString }}</span>
        <a href="{{ post | postUrl }}">{{ post.data.title }}</a>
        <span class="src">{{ post.data.source | sourceLabel }}</span>
      </li>
      {% endif %}
    {% endfor %}
  </ul>
  <p><a href="/posts/">→ 全部文章</a></p>
</section>
